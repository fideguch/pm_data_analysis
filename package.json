{
  "name": "pm-data-analysis",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npx tsc --noEmit",
    "format": "npx prettier --write '**/*.{ts,md,json,yml}'",
